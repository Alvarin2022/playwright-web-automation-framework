# Application URLs
BASE_URL=https://www.saucedemo.com

# Test Configuration
HEADLESS=true
DEFAULT_TIMEOUT=30000

# Pipeline Configuration
# Set USE_PIPELINE_CONFIG=true to read configuration from the variables below.
# When false, the framework uses default values defined in Configurator.ts.
USE_PIPELINE_CONFIG=false

# Available values:
# TEST_USER_TYPE: STANDARD | LOCKED | PROBLEM | PERFORMANCE | ERROR | VISUAL
# TEST_ENVIRONMENT: PROD | QA | UAT
# TEST_LANGUAGE: ENGLISH | SPANISH
# TEST_BROWSER: CHROMIUM | FIREFOX | WEBKIT
TEST_USER_TYPE=STANDARD
TEST_ENVIRONMENT=PROD
TEST_LANGUAGE=ENGLISH
TEST_BROWSER=CHROMIUM